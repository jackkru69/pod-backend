# App
APP_NAME=go-clean-template
APP_VERSION=1.0.0
# HTTP settings
HTTP_PORT=8080
HTTP_USE_PREFORK_MODE=false
# Logger
LOG_LEVEL=debug
# PG
PG_POOL_MAX=2
PG_URL=postgres://user:myAwEsOm3pa55@w0rd@localhost:5432/db
# gRPC
GRPC_PORT=8081
# RMQ
RMQ_RPC_SERVER=rpc_server
RMQ_RPC_CLIENT=rpc_client
RMQ_URL=amqp://guest:guest@localhost:5672/
# NATS
NATS_RPC_SERVER=rpc_server
NATS_URL=nats://guest:guest@localhost:4222/
# Metrics
METRICS_ENABLED=true
# Swagger
SWAGGER_ENABLED=true

# Game Backend - TON Center API
# Base URL for TON Center API v2 (without /api/v2/ suffix - added by client)
TON_CENTER_V2_URL=http://localhost:8082
# WebSocket URL for TON Center API v3
TON_CENTER_V3_WS_URL=ws://localhost:8081/api/v3/websocket
TON_GAME_CONTRACT_ADDRESS=EQAbc...

# Game Backend - Server
GAME_BACKEND_HTTP_PORT=3000
GAME_BACKEND_ENV=development

# Game Backend - Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# Game Backend - Circuit Breaker
CIRCUIT_BREAKER_MAX_FAILURES=5
CIRCUIT_BREAKER_TIMEOUT=60s

# Game Backend - Telegram Bot (for auth validation)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Game Backend - CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://t.me

# Game Backend - WebSocket Event Streaming (Phase 10)
# Event source: "websocket" for real-time (<2s latency) or "http" for polling (5-30s latency)
BLOCKCHAIN_EVENT_SOURCE=http
# Enable WebSocket connection to TON Center API v3
ENABLE_WEBSOCKET=false
# Max reconnection attempts before falling back to HTTP polling
WS_RECONNECT_MAX_ATTEMPTS=10
# WebSocket ping interval for connection health monitoring
WS_PING_INTERVAL=30s