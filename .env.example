# App
APP_NAME=pod-game-backend
APP_VERSION=1.0.0

# HTTP settings
# Keep this aligned with pod-tma VITE_API_URL / VITE_BACKEND_WS_URL.
HTTP_PORT=8090
HTTP_USE_PREFORK_MODE=false

# Logger
LOG_LEVEL=debug

# PostgreSQL
# `make compose-up` exposes Postgres on localhost:5433.
PG_POOL_MAX=2
PG_URL=postgres://user:myAwEsOm3pa55%40w0rd@localhost:5433/db?sslmode=disable

# gRPC
GRPC_PORT=8081

# RabbitMQ
RMQ_RPC_SERVER=rpc_server
RMQ_RPC_CLIENT=rpc_client
RMQ_URL=amqp://guest:guest@localhost:5672/

# NATS
# `make compose-up` exposes NATS on localhost:4223.
NATS_RPC_SERVER=rpc_server
NATS_URL=nats://guest:guest@localhost:4223/

# Metrics / Swagger
METRICS_ENABLED=true
SWAGGER_ENABLED=true

# Reservations
RESERVATION_TIMEOUT_SECONDS=60
RESERVATION_MAX_PER_WALLET=3
RESERVATION_CLEANUP_INTERVAL_SECONDS=5

# TON Center / gameplay
# Keep this aligned with pod-tma VITE_POD_FACTORY_ADDRESS for local validation.
TON_CENTER_V2_URL=http://localhost:8082
TON_CENTER_V3_WS_URL=ws://localhost:8081/api/v3/websocket
TON_GAME_CONTRACT_ADDRESS=EQD...replace_with_same_address_as_frontend

# Game backend
GAME_BACKEND_HTTP_PORT=8090
GAME_BACKEND_ENV=development
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m
CIRCUIT_BREAKER_MAX_FAILURES=5
CIRCUIT_BREAKER_TIMEOUT=60s
TELEGRAM_BOT_TOKEN=your_bot_token_here
CORS_ALLOWED_ORIGINS=https://localhost:5173,http://localhost:5173,https://t.me

# Blockchain event streaming
# Use "websocket" for lower-latency TON Center streaming or "http" for polling.
BLOCKCHAIN_EVENT_SOURCE=http
ENABLE_WEBSOCKET=false
# Keep restart recovery enabled unless you intentionally want to replay from LT=0
# or force the configured source instead of the persisted one.
BLOCKCHAIN_RESUME_FROM_CHECKPOINT=true
BLOCKCHAIN_RESUME_EVENT_SOURCE=true
WS_RECONNECT_MAX_ATTEMPTS=10
WS_PING_INTERVAL=30s
MIN_POLL_INTERVAL=5s
MAX_POLL_INTERVAL=30s

# Retry / observability
RETRY_MAX_RETRIES=3
RETRY_INITIAL_BACKOFF=100ms
RETRY_MAX_BACKOFF=2s
RETRY_BACKOFF_MULTIPLIER=2.0
TRACING_ENABLED=false
TRACING_OTLP_ENDPOINT=localhost:4318
